{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/*.gen.ts",
    "**/*/ui/**/*.tsx",
    "**/*/*.js",
    "packages/enclave/src/mpc/**/*.ts",
    "**/*.css",
    "**/facesign-enclave/src/assets/facetec/**/*",
    "**/facesign-enclave/public/facetec/**/*"
  ],
  "sortImports": {
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  },
  "sortTailwindcss": {}
}
