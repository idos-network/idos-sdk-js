generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WalletType {
  FaceSign
  EVM
  NEAR
  Stellar
  XRPL
}

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  walletAddress String     @unique @map("wallet_address") @db.VarChar(255)
  walletType    WalletType @map("wallet_type")

  consumerAuthPublicKey String? @map("consumer_auth_public_key") @db.VarChar(255)
  consumerAuthKey       String? @map("consumer_auth_key") @db.Text /// @encrypted
  consumerEncPublicKey  String? @map("consumer_enc_public_key") @db.VarChar(255)
  consumerEncKey        String? @map("consumer_enc_key") @db.Text /// @encrypted

  relayClientId   String? @map("relay_client_id") @db.Uuid
  relayName       String? @map("relay_name") @db.VarChar(255)
  relayPrivateKey String? @map("relay_private_key") @db.Text /// @encrypted
  relayPublicKey  String? @map("relay_public_key") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
}
